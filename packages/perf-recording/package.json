{
  "name": "@atruvia/perf-recording",
  "version": "1.0.0",
  "description": "HTTP performance recording for Cucumber and Playwright tests",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".":            { "require": "./dist/index.js",            "types": "./dist/index.d.ts" },
    "./cucumber":   { "require": "./dist/cucumber/index.js",   "types": "./dist/cucumber/index.d.ts" },
    "./playwright": { "require": "./dist/playwright/index.js", "types": "./dist/playwright/index.d.ts" },
    "./schema":     { "require": "./dist/schema.js",           "types": "./dist/schema.d.ts" }
  },
  "scripts": {
    "build":       "tsc -p tsconfig.json",
    "schema:init": "ts-node src/schema.ts"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "pg": "^8.13.3"
  },
  "peerDependencies": {
    "@playwright/test":    ">=1.40.0",
    "@cucumber/cucumber":  ">=10.0.0",
    "dotenv":              ">=16.0.0",
    "fs-extra":            ">=11.0.0"
  },
  "peerDependenciesMeta": {
    "@cucumber/cucumber": { "optional": true },
    "dotenv":             { "optional": true },
    "fs-extra":           { "optional": true }
  },
  "files": ["dist"],
  "license": "UNLICENSED"
}
