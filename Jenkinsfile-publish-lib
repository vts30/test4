pipeline {
    agent { label 'cing-base-ext' }

    environment {
        NEXUS_REGISTRY = 'https://nexus.in.fiduciagad.de/repository/business-service-platform-npm-hosted/'
        LIB_DIR        = 'packages/perf-recording'
    }

    parameters {
        string(name: 'LIB_VERSION', defaultValue: '1.0.0', description: 'Version to publish (e.g. 1.0.1)')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install dependencies') {
            steps {
                dir("${LIB_DIR}") {
                    sh 'npm config set strict-ssl false && npm config set registry https://nexus.rz.bankenit.de/repository/npm-internet-proxy/ && npm install --cache .npm'
                }
            }
        }

        stage('Build') {
            steps {
                dir("${LIB_DIR}") {
                    sh 'npm run build'
                }
            }
        }

        stage('Set version') {
            steps {
                dir("${LIB_DIR}") {
                    sh "npm version ${params.LIB_VERSION} --no-git-tag-version --allow-same-version"
                }
            }
        }

        stage('Publish to Nexus') {
            steps {
                // nexus-npm-credentials: Jenkins credential (Username with password)
                // Username: your Nexus username
                // Password: your Nexus password
                // The base64 encoding for npm _auth is done automatically below
                withCredentials([
                    usernamePassword(
                        credentialsId: 'nexus-npm-credentials',
                        usernameVariable: 'NEXUS_USER',
                        passwordVariable: 'NEXUS_PASSWORD'
                    )
                ]) {
                    dir("${LIB_DIR}") {
                        sh """
                            NPM_AUTH=\$(echo -n "\${NEXUS_USER}:\${NEXUS_PASSWORD}" | base64)
                            echo "@atruvia:registry=${NEXUS_REGISTRY}"                          > .npmrc
                            echo "//nexus.in.fiduciagad.de/repository/business-service-platform-npm-hosted/:_auth=\${NPM_AUTH}" >> .npmrc
                            echo "//nexus.in.fiduciagad.de/repository/business-service-platform-npm-hosted/:always-auth=true"   >> .npmrc
                            echo "strict-ssl=false"                                             >> .npmrc
                            npm publish --cache .npm
                        """
                    }
                }
            }
        }
    }

    post {
        success {
            echo "Published @atruvia/perf-recording@${params.LIB_VERSION} to Nexus successfully."
        }
        failure {
            echo 'Publish failed. Check logs above.'
        }
    }
}
