pipeline {
    agent { label 'cing-base-ext' }

    environment {
        NEXUS_REGISTRY = 'https://nexus.in.fiduciagad.de/repository/business-service-platform-npm-hosted/'
        LIB_DIR        = 'packages/perf-recording'
    }

    parameters {
        string(name: 'LIB_VERSION', defaultValue: '1.0.0', description: 'Version to publish (e.g. 1.0.1)')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install dependencies') {
            steps {
                dir("${LIB_DIR}") {
                    sh 'npm install'
                }
            }
        }

        stage('Build') {
            steps {
                dir("${LIB_DIR}") {
                    sh 'npm run build'
                }
            }
        }

        stage('Set version') {
            steps {
                dir("${LIB_DIR}") {
                    sh "npm version ${params.LIB_VERSION} --no-git-tag-version"
                }
            }
        }

        stage('Publish to Nexus') {
            steps {
                // nexus-npm-token: store Nexus User Token (token-username + token-password)
                // Generate in Nexus: top-right username → User Token → Access User Token
                withCredentials([
                    usernamePassword(
                        credentialsId: 'nexus-npm-token',
                        usernameVariable: 'NEXUS_TOKEN_USER',
                        passwordVariable: 'NEXUS_TOKEN_PASS'
                    )
                ]) {
                    dir("${LIB_DIR}") {
                        sh """
                            export NPM_AUTH=\$(echo -n "\${NEXUS_TOKEN_USER}:\${NEXUS_TOKEN_PASS}" | base64)
                            npm publish --registry ${NEXUS_REGISTRY}
                        """
                    }
                }
            }
        }
    }

    post {
        success {
            echo "Published @atruvia/perf-recording@${params.LIB_VERSION} to Nexus successfully."
        }
        failure {
            echo 'Publish failed. Check logs above.'
        }
    }
}
